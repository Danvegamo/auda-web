---
import { ClientRouter } from 'astro:transitions';
import Loader from '../components/Loader.astro';
import Cursor from '../components/Cursor.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = 'AUDA — Estudio AI-first para organizaciones con propósito',
  description = 'AUDA vuelve AI-first a universidades, fundaciones y empresas con propósito: auditoría, implementación e infraestructura de inteligencia artificial embebida en sus procesos.',
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;

const ogImage = new URL('/og.png', Astro.site).href;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'AUDA',
  url: 'https://auda.lat',
  logo: new URL('/favicon.svg', Astro.site).href,
  description,
  email: 'hola@auda.lat',
  areaServed: 'CO',
  knowsLanguage: ['es'],
  sameAs: [
    'https://www.linkedin.com/company/auda-lat',
    'https://github.com/danvegamo',
  ],
  makesOffer: [
    { '@type': 'Offer', name: 'Identidad visual + sitio web' },
    { '@type': 'Offer', name: 'Hosting, mantenimiento y soporte' },
    { '@type': 'Offer', name: 'Auditoría AI-first (framework AUDA AI Readiness)' },
    { '@type': 'Offer', name: 'Implementación de IA vertical' },
    { '@type': 'Offer', name: 'AI Ops Retainer' },
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,ital,wght@9..144,0,400;9..144,0,600;9..144,0,700;9..144,1,400&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(orgSchema)} />

    {/* Pre-paint theme script — evita FOUC en light/dark */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('auda:theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <Loader />
    <slot />
    <Cursor />
    <script>
      import '../scripts/theme.ts';
      import '../scripts/scroll.ts';
    </script>
  </body>
</html>
