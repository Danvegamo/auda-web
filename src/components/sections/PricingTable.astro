---
import type { Tier } from '../../lib/wp';

interface Props { tiers: Tier[] }
const { tiers } = Astro.props;
---

<section class="band" id="precios">
  <div class="wrap">
    <span class="eyebrow" data-reveal="up">Precios · Bandas vigentes</span>
    <h2 data-reveal="line">Tickets transparentes, sin humo.</h2>
    <p class="section-sub" data-reveal="up">
      Cinco capas, cinco cadencias. Las bandas son hipótesis a validar con los primeros tres
      clientes pagos; pricing definitivo tras confirmar disposición a pagar real.
    </p>

    <div class="pricing-shell" data-reveal="up">
      <table class="pricing">
        <thead>
          <tr>
            <th class="t-num">Tier</th>
            <th class="t-name">Entregable</th>
            <th class="t-ticket">Ticket</th>
            <th class="t-cad">Cadencia</th>
          </tr>
        </thead>
        <tbody>
          {tiers.map((t) => (
            <tr class={`row accent-${t.accent}`} data-cursor-grow>
              <td class="t-num"><span class="num">{t.n}</span></td>
              <td class="t-name">
                <strong>{t.title}</strong>
                <span class="sub">{t.subtitle}</span>
              </td>
              <td class="t-ticket">{t.ticket}</td>
              <td class="t-cad">{t.cadence}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .pricing-shell {
    margin-top: 40px;
    border: 1px solid var(--color-line);
    overflow-x: auto;
  }
  .pricing {
    width: 100%;
    border-collapse: collapse;
    font-variant-numeric: tabular-nums;
  }
  .pricing thead th {
    text-align: left;
    padding: 14px 18px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-mute);
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-line);
    font-weight: 600;
  }
  .pricing tbody td {
    padding: 18px;
    border-bottom: 1px solid var(--color-line);
    vertical-align: top;
    color: var(--color-text);
    font-size: 14px;
  }
  .pricing tbody tr:last-child td { border-bottom: none; }
  .pricing tbody tr {
    transition: background 0.2s ease;
  }
  .pricing tbody tr:hover { background: var(--color-surface); }

  .t-num { width: 70px; }
  .num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 600;
    color: var(--color-text);
    border: 1px solid var(--color-line);
  }
  .accent-orange .num { border-color: var(--color-orange); color: var(--color-orange-deep); }
  .accent-green .num { border-color: var(--color-green); color: var(--color-green); }
  .accent-blue .num { border-color: var(--color-blue); color: var(--color-blue); }
  .accent-ink .num { border-color: var(--color-text); }

  .t-name strong {
    display: block;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 4px;
  }
  .t-name .sub {
    display: block;
    color: var(--color-text-soft);
    font-size: 12px;
    line-height: 1.5;
  }
  .t-ticket {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text);
    white-space: nowrap;
  }
  .t-cad {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-soft);
  }

  @media (max-width: 720px) {
    .pricing thead { display: none; }
    .pricing, .pricing tbody, .pricing tr, .pricing td { display: block; width: 100%; }
    .pricing tbody tr { padding: 16px 18px; }
    .pricing tbody td { padding: 4px 0; border-bottom: none; }
    .t-num .num { margin-bottom: 8px; }
    .t-ticket, .t-cad { font-size: 12px; }
  }
</style>
