---
import TierAccent from '../svg/TierAccent.astro';
import type { Tier } from '../../lib/wp';

interface Props { tier: Tier; index: number; total: number }
const { tier, index, total } = Astro.props;
const idx = String(index + 1).padStart(2, '0');
const tot = String(total).padStart(2, '0');
---

<section
  class={`tier-story accent-${tier.accent}`}
  data-tier-story
  data-cinematic
  id={`tier-${tier.n}`}
>
  <div class="ts-axis" aria-hidden="true">
    <span class="ts-axis-id">CAPA {idx}/{tot}</span>
    <span class="ts-axis-bar"></span>
    <span class="ts-axis-name">{tier.variant.toUpperCase()}</span>
  </div>
  <div class="ts-fade-gate" aria-hidden="true"></div>
  <div class="ts-wrap">
    <div class="ts-text">
      <div class="ts-num-row">
        <span class="ts-num">{tier.n}</span>
        <span class="ts-cad">ÍNDICE · {idx} de {tot}</span>
      </div>
      <h3 class="ts-title">{tier.title}</h3>
      <p class="ts-sub">{tier.subtitle}</p>
      <ul class="ts-bullets">
        {tier.bullets.map((b) => <li>{b}</li>)}
      </ul>
      <p class="ts-outcome">
        <span class="ts-arrow" aria-hidden="true">→</span>
        {tier.outcome}
      </p>
    </div>
    <div class="ts-visual">
      <TierAccent variant={tier.variant} accent={tier.accent} />
    </div>
  </div>
</section>

<style>
  .tier-story {
    padding: clamp(80px, 12vw, 130px) 6vw;
    border-bottom: 1px solid var(--color-line);
    position: relative;
    overflow: hidden;
  }
  .ts-axis {
    position: absolute;
    top: 28px;
    left: 6vw;
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--color-mute);
    z-index: 1;
  }
  .ts-axis-bar {
    display: inline-block;
    width: 40px;
    height: 1px;
    background: var(--color-orange);
  }
  .ts-axis-name { color: var(--color-orange-deep); }
  .ts-fade-gate {
    position: absolute;
    inset: 0;
    background: var(--color-bg);
    opacity: 0;
    pointer-events: none;
    z-index: 2;
  }
  .ts-wrap {
    max-width: 1040px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .ts-num-row {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 24px;
  }
  .ts-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 600;
    color: var(--color-text);
    border: 1px solid var(--color-line);
  }
  .accent-orange .ts-num { border-color: var(--color-orange); color: var(--color-orange-deep); }
  .accent-green .ts-num { border-color: var(--color-green); color: var(--color-green); }
  .accent-blue .ts-num { border-color: var(--color-blue); color: var(--color-blue); }
  .accent-ink .ts-num { border-color: var(--color-text); }

  .ts-cad {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-mute);
  }
  .ts-title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.08;
    margin: 0 0 14px;
    color: var(--color-text);
    letter-spacing: -0.015em;
  }
  .ts-sub {
    font-size: 16px;
    color: var(--color-text-soft);
    margin: 0 0 26px;
    line-height: 1.5;
  }
  .ts-bullets {
    list-style: none;
    margin: 0 0 28px;
    padding: 0;
    border-left: 1px solid var(--color-line);
  }
  .ts-bullets li {
    padding: 8px 0 8px 18px;
    color: var(--color-text);
    font-size: 14px;
    position: relative;
  }
  .ts-bullets li::before {
    content: '';
    position: absolute;
    left: -3px;
    top: 16px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-orange);
  }
  .ts-outcome {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 16px;
    line-height: 1.5;
    color: var(--color-text);
    margin: 0;
    padding: 18px 22px;
    background: var(--color-surface);
    border-left: 3px solid var(--color-orange);
  }
  .ts-arrow {
    color: var(--color-orange);
    font-style: normal;
    font-weight: 600;
  }
  .ts-visual {
    position: relative;
    transform-origin: center;
    will-change: transform, filter, opacity;
  }

  @media (max-width: 880px) {
    .ts-wrap {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .ts-visual { order: -1; max-width: 320px; margin: 0 auto; }
    .ts-axis { top: 16px; }
  }
</style>
