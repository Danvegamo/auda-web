---
import AudaMark from '../AudaMark.astro';

interface Props {
  email: string;
  whatsapp: string;
}
const { email, whatsapp } = Astro.props;
const wa = whatsapp.replace(/[^0-9]/g, '');
---

<section class="band band-dark auda-grid" id="contacto">
  <div class="wrap">
    <div class="contact-grid">
      <div class="contact-mark">
        <AudaMark size={120} />
        <span class="contact-tag">Productos y servicios audaces</span>
      </div>
      <div class="contact-body">
        <span class="eyebrow on-dark" data-reveal="up">Contacto</span>
        <h2 class="on-dark" data-reveal="line">Construyamos tu sistema de IA.</h2>
        <p class="body-lg on-dark" data-reveal="up">
          Una auditoría AI-first arranca con una conversación. Sin humo, sin caja negra.
        </p>
        <ul class="contact-list" data-reveal="stagger">
          <li><span class="cl-k">WhatsApp</span><a href={`https://wa.me/${wa}`} data-cursor-grow>{whatsapp}</a></li>
          <li><span class="cl-k">Correo</span><a href={`mailto:${email}`} data-cursor-grow>{email}</a></li>
          <li><span class="cl-k">Web</span><a href="https://auda.lat" data-cursor-grow>auda.lat</a></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 56px;
    align-items: center;
  }
  .contact-mark {
    display: flex;
    flex-direction: column;
    gap: 18px;
    color: var(--color-paper);
  }
  .contact-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: rgba(237, 230, 214, 0.6);
  }
  .contact-list {
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
    display: grid;
    gap: 1px;
    background: rgba(237, 230, 214, 0.12);
    border: 1px solid rgba(237, 230, 214, 0.12);
  }
  .contact-list li {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 14px 18px;
    background: var(--color-ink-deep);
  }
  .cl-k {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(237, 230, 214, 0.5);
    width: 90px;
    flex-shrink: 0;
  }
  .contact-list a {
    color: var(--color-paper);
    text-decoration: none;
    font-size: 16px;
    transition: color 0.2s;
  }
  .contact-list a:hover { color: var(--color-orange); }
  @media (max-width: 720px) {
    .contact-grid { grid-template-columns: 1fr; gap: 36px; }
  }
</style>
