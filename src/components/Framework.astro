---
const phases = [
  { id: 'R1', name: 'Read', desc: 'Diagnóstico organizacional: procesos, dolor, datos, madurez.' },
  { id: 'R2', name: 'Rank', desc: 'Priorización por ROI: 5–8 oportunidades de IA con quick-wins.' },
  { id: 'R3', name: 'Roadmap', desc: 'Plan a 12 meses: cronograma, capacitación, presupuesto, KPIs.' },
  { id: 'R4', name: 'Run', desc: 'Implementación embebida: IA operando, equipo entrenado.' },
  { id: 'R5', name: 'Refine', desc: 'Mejora continua: iteraciones, nuevos casos, monitoreo.' },
];
---

<div class="framework-wrap">
  <!-- SVG line drawn with scroll -->
  <svg class="fw-line" viewBox="0 0 800 2" preserveAspectRatio="none" aria-hidden="true">
    <path
      data-draw
      d="M 0 1 L 800 1"
      stroke="rgba(232,130,90,0.5)"
      stroke-width="1"
      stroke-dasharray="6 6"
      fill="none"
    />
  </svg>

  <ol class="framework">
    {
      phases.map((p, i) => (
        <li class="phase" style={`--i:${i}`} data-reveal="up">
          <div class="dot">
            <span class="dot-id">{p.id}</span>
          </div>
          <h4>{p.name}</h4>
          <p>{p.desc}</p>
        </li>
      ))
    }
  </ol>
</div>

<style>
  .framework-wrap {
    position: relative;
    padding-top: 8px;
  }
  .fw-line {
    position: absolute;
    top: 30px;
    left: 4%;
    right: 4%;
    width: 92%;
    height: 2px;
    pointer-events: none;
    z-index: 0;
  }
  .framework {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
    position: relative;
  }
  .phase {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid rgba(232,130,90,0.4);
    background: var(--color-surface);
    margin-bottom: 16px;
    position: relative;
  }
  .dot::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid rgba(232,130,90,0.12);
  }
  .dot-id {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.05em;
  }
  .phase:nth-child(1) .dot { border-color: rgba(232,130,90,0.7); }
  .phase:nth-child(2) .dot { border-color: rgba(208,106,68,0.6); }
  .phase:nth-child(3) .dot { border-color: rgba(92,124,90,0.6); }
  .phase:nth-child(4) .dot { border-color: rgba(62,92,118,0.6); }
  .phase:nth-child(5) .dot { border-color: rgba(240,236,228,0.3); }

  .phase:nth-child(1) .dot-id { color: #e8825a; }
  .phase:nth-child(2) .dot-id { color: #d06a44; }
  .phase:nth-child(3) .dot-id { color: #5c7c5a; }
  .phase:nth-child(4) .dot-id { color: #3e5c76; }
  .phase:nth-child(5) .dot-id { color: var(--color-text); }

  .phase h4 {
    margin: 0 0 8px;
    font-size: 15px;
    font-family: var(--font-serif);
    color: var(--color-text);
  }
  .phase p {
    margin: 0;
    font-size: 12px;
    color: var(--color-text-soft);
    line-height: 1.5;
  }

  @media (max-width: 720px) {
    .fw-line { display: none; }
    .framework {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .phase {
      display: grid;
      grid-template-columns: 46px 1fr;
      gap: 16px;
      text-align: left;
      align-items: start;
    }
    .dot { margin-bottom: 0; }
    .phase h4 { grid-column: 2; }
    .phase p { grid-column: 2; }
  }
</style>
