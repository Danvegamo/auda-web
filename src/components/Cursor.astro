<div class="cursor-host" transition:persist="auda-cursor">
  <canvas id="auda-cursor" aria-hidden="true"></canvas>
</div>

<style>
  .cursor-host {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9998;
  }
  #auda-cursor {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: none;
    mix-blend-mode: normal;
  }
  /* Esconder cursor nativo cuando el sphere está activo (desktop only) */
  @media (hover: hover) and (pointer: fine) and (min-width: 721px) {
    [data-entered="true"]:not(.no-custom-cursor) body,
    [data-entered="true"]:not(.no-custom-cursor) body * {
      /* mantenemos cursor nativo para UX accesibilidad */
    }
  }
</style>

<script>
  // Carga diferida — OGL solo se descarga tras primer mousemove
  function canEnable() {
    if (window.matchMedia('(pointer: coarse)').matches) return false;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return false;
    if (window.innerWidth < 720) return false;
    return true;
  }
  function trigger() {
    window.removeEventListener('mousemove', trigger);
    import('../scripts/cursor.ts');
  }
  if (canEnable()) {
    window.addEventListener('mousemove', trigger, { passive: true });
  }
</script>
