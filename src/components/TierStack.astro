---
interface Tier {
  n: string;
  title: string;
  body: string;
  accent: 'orange' | 'green' | 'blue' | 'ink';
}
interface Props {
  tiers: Tier[];
}
const { tiers } = Astro.props;
const accentVar: Record<Tier['accent'], string> = {
  orange: 'var(--color-accent)',
  green: 'var(--color-green)',
  blue: 'var(--color-blue)',
  ink: 'rgba(240,236,228,0.4)',
};
---

<div class="tier-stack" data-reveal="stagger">
  {
    tiers.map((t) => (
      <article class="tier" style={`--accent:${accentVar[t.accent]}`}>
        <div class="tier-num">{t.n}</div>
        <div class="tier-body">
          <h3>{t.title}</h3>
          <p>{t.body}</p>
        </div>
        <div class="tier-line"></div>
      </article>
    ))
  }
</div>

<style>
  .tier-stack {
    display: grid;
    gap: 1px;
    background: var(--color-line);
    border: 1px solid var(--color-line);
  }
  .tier {
    display: grid;
    grid-template-columns: 72px 1fr;
    align-items: stretch;
    background: var(--color-surface);
    position: relative;
    overflow: hidden;
    transition: background 0.25s ease;
  }
  .tier::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.35s ease;
  }
  .tier:hover {
    background: #161616;
  }
  .tier:hover::before {
    transform: scaleY(1);
  }
  .tier-num {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.05em;
    border-right: 1px solid var(--color-line);
    padding: 20px 0;
  }
  .tier-body {
    padding: 18px 24px;
  }
  .tier-body h3 {
    margin: 0 0 6px;
    font-size: 16px;
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--color-text);
  }
  .tier-body p {
    margin: 0;
    color: var(--color-text-soft);
    font-size: 14px;
    line-height: 1.55;
  }
  @media (max-width: 640px) {
    .tier {
      grid-template-columns: 48px 1fr;
    }
    .tier-num {
      font-size: 10px;
    }
  }
</style>
