---
// Monograma geométrico AUDA (2×2): A triángulo · U cuenco · D semidisco · A triángulo.
// Partes "tinta" usan currentColor → funciona sobre papel y sobre fondo oscuro.
interface Props {
  size?: number;
  class?: string;
}
const { size = 32, class: cls = '' } = Astro.props;
---

<svg
  class={`auda-mark ${cls}`}
  width={size}
  height={size}
  viewBox="0 0 100 100"
  fill="none"
  role="img"
  aria-label="AUDA"
>
  <!-- A · triángulo terracota (arriba-izq) -->
  <polygon points="25,8 8,42 42,42" fill="var(--color-orange)" />
  <!-- U · cuenco tinta (arriba-der) -->
  <path d="M58 12 A17 17 0 0 0 92 12 Z" fill="currentColor" />
  <!-- D · semidisco terracota (abajo-izq) -->
  <path d="M8 58 A17 17 0 0 1 8 92 Z" fill="var(--color-orange)" />
  <!-- A · triángulo tinta (abajo-der) -->
  <polygon points="75,58 58,92 92,92" fill="currentColor" />
</svg>

<style>
  .auda-mark { display: block; flex-shrink: 0; }
</style>
