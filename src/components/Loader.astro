---
---

<div id="loader" aria-hidden="true">
  <div class="l-grid auda-lines"></div>
  <div class="l-content">
    <div class="l-counter"><span id="l-pct">001</span></div>
    <div class="l-line-wrap">
      <div class="l-line"></div>
    </div>
    <div class="l-sub">AUDA · Estudio AI-first</div>

    <div class="l-gate">
      <button id="l-enter-sound" class="l-enter" type="button">[ ACTIVAR ENTORNO ACÚSTICO ]</button>
      <button id="l-enter-mute" class="l-enter l-enter-mute" type="button">entrar en silencio</button>
    </div>
  </div>
</div>

<style>
  #loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .l-grid {
    position: absolute;
    inset: 0;
    opacity: 0;
  }
  .l-content {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }
  .l-counter {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(72px, 14vw, 150px);
    line-height: 1;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }
  .l-line-wrap {
    width: min(420px, 70vw);
    height: 1px;
    background: var(--color-line);
    position: relative;
    overflow: hidden;
  }
  .l-line {
    position: absolute;
    inset: 0;
    background: var(--color-text);
    transform-origin: left;
    transform: scaleX(0);
  }
  .l-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--color-text-soft);
    opacity: 0;
  }
  .l-gate {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-top: 12px;
    opacity: 0;
    pointer-events: auto; /* clickable from start — fade es solo visual */
  }
  .l-gate.ready { pointer-events: auto; }
  .l-enter {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    padding: 6px 4px;
    transition: color 0.2s, letter-spacing 0.3s;
  }
  .l-enter:hover { letter-spacing: 0.24em; }
  .l-enter-mute {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: lowercase;
    color: var(--color-text-soft);
  }
  .l-enter-mute:hover { color: var(--color-text); }
</style>

<script>
  import { gsap } from 'gsap';
  import { startAmbient, dryClick } from '../scripts/audio';

  function runLoader() {
    const loader = document.getElementById('loader');
    if (!loader) return;
    loader.style.display = 'flex';

    const grid = loader.querySelector<HTMLElement>('.l-grid');
    const line = loader.querySelector<HTMLElement>('.l-line');
    const sub = loader.querySelector<HTMLElement>('.l-sub');
    const gate = loader.querySelector<HTMLElement>('.l-gate');
    const pct = document.getElementById('l-pct');
    const btnSound = document.getElementById('l-enter-sound');
    const btnMute = document.getElementById('l-enter-mute');

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let revealed = false;
    function reveal(withSound: boolean) {
      if (revealed) return;
      revealed = true;
      if (withSound) {
        try { startAmbient(); dryClick(); } catch {}
      }
      gsap.to(loader, {
        opacity: 0,
        duration: 0.6,
        ease: 'power2.inOut',
        onComplete: () => { loader!.style.display = 'none'; },
      });
      document.documentElement.dataset.entered = 'true';
      try { sessionStorage.setItem('auda:entered', '1'); } catch {}
    }

    btnSound?.addEventListener('click', () => reveal(true));
    btnMute?.addEventListener('click', () => reveal(false));

    // Auto-dismiss fail-safe: 3s tras carga, si user no interactúa
    // entra en modo silencio automático. Evita bloqueo perpetuo en
    // entornos sin gesture (VSCode preview, headless, etc).
    setTimeout(() => reveal(false), 3000);

    if (reduce) {
      gsap.set([sub, gate], { opacity: 1 });
      gate?.classList.add('ready');
      if (pct) pct.textContent = '100';
      return;
    }

    const tl = gsap.timeline();
    tl.to(grid, { opacity: 1, duration: 0.6, ease: 'power2.out' }, 0);

    // contador 001 → 100
    const obj = { val: 1 };
    tl.to(obj, {
      val: 100,
      duration: 1.6,
      ease: 'expo.out',
      onUpdate: () => {
        if (pct) pct.textContent = String(Math.round(obj.val)).padStart(3, '0');
      },
    }, 0.1);

    // línea avanza con aceleración asimétrica
    tl.to(line, { scaleX: 1, duration: 1.6, ease: 'expo.out' }, 0.1);

    // parpadeo seco del contador al llegar a 100
    tl.to(pct, { opacity: 0.2, duration: 0.05, repeat: 3, yoyo: true }, '>-0.1');

    // sub + puerta acústica
    tl.to(sub, { opacity: 1, duration: 0.5, ease: 'power2.out' }, '>');
    tl.to(gate, { opacity: 1, duration: 0.5, ease: 'power2.out',
      onStart: () => gate?.classList.add('ready') }, '<+0.1');
  }

  let booted = false;
  function boot() {
    if (booted) return;
    booted = true;
    // Cold-only: si ya entró en esta sesión, saltar loader (no doble en navegación interna)
    if (sessionStorage.getItem('auda:entered') === '1') {
      const loader = document.getElementById('loader');
      if (loader) loader.style.display = 'none';
      document.documentElement.dataset.entered = 'true';
      return;
    }
    runLoader();
  }
  document.addEventListener('astro:page-load', boot);
  if (document.readyState !== 'loading') boot();
  else document.addEventListener('DOMContentLoaded', boot);
</script>
