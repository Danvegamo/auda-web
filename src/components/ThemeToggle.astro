---
---

<button
  type="button"
  class="theme-toggle"
  data-theme-toggle
  data-cursor-grow
  aria-label="Alternar modo claro / oscuro"
  title="Modo claro / oscuro"
>
  <svg class="ic ic-sun" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="4" fill="currentColor" />
    <g stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
      <line x1="12" y1="2.5" x2="12" y2="5" />
      <line x1="12" y1="19" x2="12" y2="21.5" />
      <line x1="2.5" y1="12" x2="5" y2="12" />
      <line x1="19" y1="12" x2="21.5" y2="12" />
      <line x1="5.2" y1="5.2" x2="6.9" y2="6.9" />
      <line x1="17.1" y1="17.1" x2="18.8" y2="18.8" />
      <line x1="5.2" y1="18.8" x2="6.9" y2="17.1" />
      <line x1="17.1" y1="6.9" x2="18.8" y2="5.2" />
    </g>
  </svg>
  <svg class="ic ic-moon" viewBox="0 0 24 24" aria-hidden="true">
    <path
      d="M20.5 14.2A8 8 0 0 1 9.8 3.5a8 8 0 1 0 10.7 10.7z"
      fill="currentColor"
    />
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: transparent;
    border: 1px solid var(--color-line);
    color: var(--color-text);
    cursor: pointer;
    padding: 0;
    position: relative;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .theme-toggle:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .ic {
    width: 18px;
    height: 18px;
    position: absolute;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  [data-theme="light"] .ic-sun { opacity: 1; transform: scale(1) rotate(0); }
  [data-theme="light"] .ic-moon { opacity: 0; transform: scale(0.6) rotate(-90deg); }
  [data-theme="dark"] .ic-sun { opacity: 0; transform: scale(0.6) rotate(90deg); }
  [data-theme="dark"] .ic-moon { opacity: 1; transform: scale(1) rotate(0); }
</style>
