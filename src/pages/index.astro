---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Manifesto from '../components/sections/Manifesto.astro';
import TierStory from '../components/sections/TierStory.astro';
import Framework from '../components/sections/Framework.astro';
import Verticals from '../components/sections/Verticals.astro';
import Team from '../components/sections/Team.astro';
import BookingCTA from '../components/sections/BookingCTA.astro';
import Contact from '../components/sections/Contact.astro';
import VideoParallax from '../components/VideoParallax.astro';
import FormulaIntro from '../components/sections/FormulaIntro.astro';
import { getContent } from '../lib/wp';

const c = await getContent();
---

<BaseLayout>
  <Hero tagline={c.tagline} intro={c.intro} email={c.contact.email} />

  <main>
    <Manifesto lines={c.manifesto.lines} />

    <VideoParallax
      slot="bridge"
      variant="bridge"
      height="full"
      mood="warm"
      eyebrow="Principios · Oficio"
      heading="Hacemos lo invisible visible."
      body="Antes de escribir una línea, escribimos los principios. Antes del agente, el manifiesto."
    />

    <About heading={c.about.heading} body={c.about.body} />

    <FormulaIntro />

    <TierStory tiers={c.tiers} />

    <section class="band" id="framework">
      <div class="wrap">
        <span class="eyebrow" data-reveal="up">Metodología</span>
        <h2 data-reveal="line">AUDA AI Readiness</h2>
        <p class="section-sub" data-reveal="up">
          No vendemos horas: vendemos un framework. Cinco fases, cada una un entregable nombrable
          y repetible. En cuatro semanas: diagnóstico, roadmap y plan de capacitación.
        </p>
        <Framework />
      </div>
    </section>

    <div class="divider" aria-hidden="true"></div>

    <Verticals verticals={c.verticals} />

    <div class="divider" aria-hidden="true"></div>

    <Team team={c.team} />

    <BookingCTA
      calendarUrl={c.contact.calendarUrl}
      email={c.contact.email}
      whatsapp={c.contact.whatsapp}
    />

    <Contact email={c.contact.email} whatsapp={c.contact.whatsapp} />
  </main>

  <footer class="site-foot">
    <span>AUDA · Estudio AI-first · Bogotá / Medellín</span>
    <span>{c.contact.email}</span>
  </footer>
</BaseLayout>

<script>
  import { toggleAmbient } from '../scripts/audio';
  function wire() {
    const btn = document.getElementById('sound-toggle');
    if (!btn || btn.dataset.wired) return;
    btn.dataset.wired = 'true';
    btn.addEventListener('click', () => {
      const on = toggleAmbient();
      btn.classList.toggle('on', on);
    });
  }
  document.addEventListener('astro:page-load', wire);
  wire();
</script>

<style>
  .site-foot {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    padding: 24px 6vw;
    background: var(--color-bg);
    color: var(--color-mute);
    font-size: 11px;
    letter-spacing: 0.06em;
    border-top: 1px solid var(--color-line);
    font-family: var(--font-mono);
  }
</style>
