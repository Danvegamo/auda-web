---
import BaseLayout from '../layouts/BaseLayout.astro';
import DotField from '../components/DotField.astro';
import TierStack from '../components/TierStack.astro';
import Framework from '../components/Framework.astro';
import { getContent } from '../lib/wp';

const c = await getContent();
---

<BaseLayout>
  <!-- HERO -->
  <header class="hero auda-lines">
    <DotField />
    <nav class="nav">
      <a class="brand" href="/" aria-label="AUDA inicio">
        <svg viewBox="0 0 64 64" width="32" height="32" aria-hidden="true">
          <circle cx="22" cy="26" r="11" fill="var(--color-accent)" />
          <path d="M40 15 L51 37 L29 37 Z" fill="var(--color-text)" />
          <rect x="14" y="44" width="36" height="6" rx="3" fill="var(--color-green)" />
        </svg>
        <span class="brand-word">AUDA</span>
      </a>
      <div class="nav-links">
        <a href="#servicios">Servicios</a>
        <a href="#framework">Metodología</a>
        <a href="#contacto" class="nav-cta">Contactar</a>
      </div>
    </nav>

    <div class="hero-inner">
      <div class="hero-eyebrow" data-reveal="up">
        <span class="dot-accent"></span>
        Estudio AI-first · Bogotá / Medellín
      </div>
      <h1 data-reveal="line">{c.tagline}</h1>
      <p class="lead" data-reveal="up">{c.intro}</p>
      <div class="cta-row" data-reveal="up">
        <a class="btn btn-primary" href="#servicios">Ver servicios</a>
        <a class="btn btn-ghost" href={`mailto:${c.contact.email}`}>Hablar con AUDA</a>
      </div>
    </div>

    <div class="hero-foot">
      <div class="scroll-hint" aria-hidden="true">
        <span class="sh-line"></span>
        <span class="sh-label">scroll</span>
      </div>
      <div class="hero-coord" aria-hidden="true">4.7110° N / 74.0721° W</div>
    </div>
  </header>

  <main>
    <!-- QUÉ ES -->
    <section class="band" id="que-es">
      <div class="wrap narrow">
        <span class="eyebrow" data-reveal="up">Qué es AUDA</span>
        <h2 data-reveal="line">{c.about.heading}</h2>
        {c.about.body.map((p) => <p class="body-lg" data-reveal="up">{p}</p>)}
      </div>
    </section>

    <!-- DIVISOR -->
    <div class="divider" aria-hidden="true">
      <svg viewBox="0 0 1200 2" preserveAspectRatio="none">
        <line x1="0" y1="1" x2="1200" y2="1" stroke="rgba(255,255,255,0.06)" stroke-width="1" />
      </svg>
    </div>

    <!-- SERVICIOS / TIERS -->
    <section class="band" id="servicios">
      <div class="wrap">
        <span class="eyebrow" data-reveal="up">Servicios</span>
        <h2 data-reveal="line">Cinco capas, una sola relación.</h2>
        <p class="section-sub" data-reveal="up">
          Entrada de baja fricción, recurrencia sólida, consultoría de alto valor. El flujo
          natural sube por sí solo si el trabajo es bueno.
        </p>
        <TierStack tiers={c.tiers} />
      </div>
    </section>

    <!-- DIVISOR -->
    <div class="divider" aria-hidden="true">
      <svg viewBox="0 0 1200 2" preserveAspectRatio="none">
        <line x1="0" y1="1" x2="1200" y2="1" stroke="rgba(255,255,255,0.06)" stroke-width="1" />
      </svg>
    </div>

    <!-- FRAMEWORK -->
    <section class="band" id="framework">
      <div class="wrap">
        <span class="eyebrow" data-reveal="up">Metodología</span>
        <h2 data-reveal="line">AUDA AI Readiness</h2>
        <p class="section-sub" data-reveal="up">
          No vendemos horas: vendemos un framework. Cinco fases, cada una un entregable nombrable
          y repetible. En cuatro semanas: diagnóstico, roadmap y plan de capacitación.
        </p>
        <Framework />
      </div>
    </section>

    <!-- DIVISOR -->
    <div class="divider" aria-hidden="true">
      <svg viewBox="0 0 1200 2" preserveAspectRatio="none">
        <line x1="0" y1="1" x2="1200" y2="1" stroke="rgba(255,255,255,0.06)" stroke-width="1" />
      </svg>
    </div>

    <!-- PARA QUIÉN -->
    <section class="band" id="para-quien">
      <div class="wrap">
        <span class="eyebrow" data-reveal="up">Para quién</span>
        <h2 data-reveal="line">Organizaciones con propósito.</h2>
        <div class="vert-grid" data-reveal="stagger">
          {
            c.verticals.map((v) => (
              <article class="vert-card">
                <span class="tag">{v.tag}</span>
                <h3>{v.title}</h3>
                <p>{v.pain}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- DIVISOR -->
    <div class="divider" aria-hidden="true">
      <svg viewBox="0 0 1200 2" preserveAspectRatio="none">
        <line x1="0" y1="1" x2="1200" y2="1" stroke="rgba(255,255,255,0.06)" stroke-width="1" />
      </svg>
    </div>

    <!-- EQUIPO -->
    <section class="band" id="equipo">
      <div class="wrap narrow">
        <span class="eyebrow" data-reveal="up">Equipo</span>
        <h2 data-reveal="line">Dos lados complementarios. Ninguno sobra.</h2>
        <div class="team-grid" data-reveal="stagger">
          {
            c.team.map((m) => (
              <article class="team-card">
                <div class="team-accent"></div>
                <h3>{m.name}</h3>
                <p class="role">{m.role}</p>
                <p class="focus">{m.focus}</p>
              </article>
            ))
          }
        </div>
        <p class="rule" data-reveal="up">
          <strong>Regla de oro:</strong> Aura abre y cierra; Dan diagnostica y construye; ambos
          validan en cada hito. Ningún cliente trabaja con uno solo de los dos.
        </p>
      </div>
    </section>

    <!-- CONTACTO -->
    <section class="band band-accent auda-grid" id="contacto">
      <div class="wrap narrow">
        <span class="eyebrow accent-eye" data-reveal="up">Contacto</span>
        <h2 class="on-accent" data-reveal="line">Construyamos tu sistema de IA.</h2>
        <p class="body-lg on-accent" data-reveal="up">
          Una auditoría AI-first arranca con una conversación. Sin humo, sin caja negra.
        </p>
        <div class="cta-row" data-reveal="up">
          <a class="btn btn-inv" href={`mailto:${c.contact.email}`}>{c.contact.email}</a>
          <a
            class="btn btn-ghost-inv"
            href={`https://wa.me/${c.contact.whatsapp.replace(/[^0-9]/g, '')}`}>
            WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-foot">
    <span>AUDA · Estudio AI-first · Bogotá / Medellín</span>
    <span>{c.contact.email}</span>
  </footer>
</BaseLayout>

<style>
  /* NAV */
  .nav {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 6vw;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .brand-word {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 0.2em;
    color: var(--color-text);
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .nav-links a {
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--color-text-soft);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--color-text); }
  .nav-cta {
    padding: 8px 18px;
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--color-text) !important;
    transition: border-color 0.2s, background 0.2s !important;
  }
  .nav-cta:hover {
    border-color: var(--color-accent) !important;
    background: rgba(232,130,90,0.08);
  }

  /* HERO */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 6vw 80px;
    overflow: hidden;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 820px;
  }
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-text-soft);
    margin-bottom: 28px;
  }
  .dot-accent {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }
  .hero h1 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(40px, 6.5vw, 80px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin: 0 0 24px;
    color: var(--color-text);
  }
  .lead {
    font-size: clamp(16px, 2vw, 19px);
    color: var(--color-text-soft);
    max-width: 580px;
    margin: 0 0 36px;
    line-height: 1.6;
  }
  .hero-foot {
    position: absolute;
    bottom: 36px;
    left: 6vw;
    right: 6vw;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .scroll-hint {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .sh-line {
    display: block;
    width: 40px;
    height: 1px;
    background: var(--color-accent);
    animation: sh-pulse 2s ease-in-out infinite;
  }
  @keyframes sh-pulse {
    0%, 100% { opacity: 0.3; transform: scaleX(0.6); transform-origin: left; }
    50% { opacity: 1; transform: scaleX(1); }
  }
  .sh-label {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-text-soft);
  }
  .hero-coord {
    font-family: var(--font-mono);
    font-size: 10px;
    color: rgba(240,236,228,0.2);
    letter-spacing: 0.08em;
  }

  /* BANDS */
  .band {
    padding: clamp(80px, 12vw, 140px) 6vw;
  }
  .wrap {
    max-width: 1040px;
    margin: 0 auto;
  }
  .narrow {
    max-width: 760px;
  }
  .divider {
    padding: 0 6vw;
  }
  .divider svg {
    width: 100%;
    height: 1px;
    display: block;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 20px;
    font-weight: 600;
    font-family: var(--font-mono);
  }
  .eyebrow::before {
    content: '';
    display: inline-block;
    width: 20px;
    height: 1px;
    background: currentColor;
  }
  .accent-eye { color: rgba(10,10,10,0.5); }
  h2 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(30px, 4.5vw, 52px);
    line-height: 1.06;
    padding-bottom: 0.1em; /* prevents descenders from getting cut off */
    margin: 0 0 32px;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }
  .on-accent { color: #0a0a0a; }
  .section-sub {
    max-width: 600px;
    color: var(--color-text-soft);
    font-size: 15px;
    margin: 0 0 40px;
    line-height: 1.65;
  }
  .body-lg {
    font-size: 17px;
    line-height: 1.65;
    color: var(--color-text-soft);
    margin: 0 0 16px;
  }

  /* VERTICALES */
  .vert-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-line);
    border: 1px solid var(--color-line);
    margin-top: 40px;
  }
  .vert-card {
    background: var(--color-surface);
    padding: 28px 24px;
    transition: background 0.25s ease;
  }
  .vert-card:hover {
    background: #161616;
  }
  .vert-card .tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    border: 1px solid rgba(232,130,90,0.3);
    padding: 3px 10px;
    margin-bottom: 16px;
  }
  .vert-card h3 {
    margin: 0 0 10px;
    font-size: 17px;
    color: var(--color-text);
    font-family: var(--font-serif);
  }
  .vert-card p {
    margin: 0;
    color: var(--color-text-soft);
    font-size: 13px;
    line-height: 1.6;
  }

  /* EQUIPO */
  .team-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-line);
    border: 1px solid var(--color-line);
    margin: 32px 0 28px;
  }
  .team-card {
    background: var(--color-surface);
    padding: 28px;
    position: relative;
    overflow: hidden;
    transition: background 0.25s ease;
  }
  .team-card:hover {
    background: #161616;
  }
  .team-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-blue));
  }
  .team-card h3 {
    margin: 0 0 6px;
    font-size: 18px;
    color: var(--color-text);
  }
  .team-card .role {
    margin: 0 0 12px;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 600;
    font-family: var(--font-mono);
  }
  .team-card .focus {
    margin: 0;
    font-size: 14px;
    color: var(--color-text-soft);
    line-height: 1.6;
  }
  .rule {
    font-size: 14px;
    color: var(--color-text-soft);
    border-left: 2px solid var(--color-accent);
    padding-left: 18px;
    line-height: 1.65;
    margin: 0;
  }
  .rule strong {
    color: var(--color-text);
  }

  /* CONTACTO */
  .band-accent {
    background: var(--color-accent);
  }
  .band-accent .eyebrow::before {
    background: rgba(10,10,10,0.4);
  }
  .band-accent h2 { color: #0a0a0a; }
  .band-accent .body-lg { color: rgba(10,10,10,0.65); }

  /* CTA */
  .cta-row {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 8px;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn-primary {
    background: var(--color-accent);
    color: #0a0a0a;
  }
  .btn-primary:hover { background: var(--color-accent-deep); }
  .btn-ghost {
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--color-text);
  }
  .btn-ghost:hover { border-color: var(--color-accent); }
  .btn-inv {
    background: #0a0a0a;
    color: var(--color-text);
  }
  .btn-inv:hover { background: #1a1a1a; }
  .btn-ghost-inv {
    border: 1px solid rgba(10,10,10,0.25);
    color: #0a0a0a;
  }
  .btn-ghost-inv:hover { border-color: #0a0a0a; }

  /* FOOTER */
  .site-foot {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    padding: 24px 6vw;
    background: var(--color-bg);
    color: var(--color-mute);
    font-size: 11px;
    letter-spacing: 0.06em;
    border-top: 1px solid var(--color-line);
    font-family: var(--font-mono);
  }

  @media (max-width: 720px) {
    .nav-links { display: none; }
    .vert-grid,
    .team-grid {
      grid-template-columns: 1fr;
    }
    .hero-coord { display: none; }
  }
</style>
